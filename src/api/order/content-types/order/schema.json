{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "admin_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "admin::user"
    },
    "order_id": {
      "type": "biginteger"
    },
    "order_updated_at": {
      "type": "datetime"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "preparing",
        "delivered",
        "cancelled"
      ]
    },
    "total_amount": {
      "type": "decimal"
    },
    "order_created_at": {
      "type": "datetime"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::item.item"
    }
  }
}
